{
  "name": "docu-stream",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:frontend": "vite --config frontend/vite.config.ts",
    "dev:backend": "node --watch backend/src/server.js",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "tsc -b frontend/tsconfig.json && vite build --config frontend/vite.config.ts",
    "build:backend": "node --check backend/src/env.js && node --check backend/src/auth-service.js && node --check backend/src/app.js && node --check backend/src/server.js && node --check backend/src/upload-service.js && node --check backend/src/report-service.js && node --check api/upload.js && node --check api/health.js && node --check api/auth/session.js && node --check api/auth/logout.js && node --check api/media/upload.js && node --check api/content/items.js && node --check api/reports/monthly-release.js && node --check api/reports/monthly-release/coda.js",
    "lint": "eslint frontend",
    "preview": "vite preview --config frontend/vite.config.ts"
  },
  "dependencies": {
    "@cyntler/react-doc-viewer": "^1.17.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@tabler/icons-react": "^3.44.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.100.11",
    "@tanstack/react-router": "^1.170.4",
    "@tanstack/react-router-devtools": "^1.167.0",
    "axios": "^1.16.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tanstack/router-plugin": "^1.168.6",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
